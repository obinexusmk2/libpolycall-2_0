# Docker build context boundary
#
# Keep the production image focused on source code, build metadata, and runtime
# configuration. Documentation, screenshots, generated outputs, and local tool
# caches stay outside the image layers.

.git/
.gitignore
.dockerignore

# Build outputs
build/
_docker_build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
**/target/
**/dist/
**/node_modules/
**/__pycache__/
**/.pytest_cache/
*.o
*.a
*.so
*.dll
*.dylib
*.lib
*.exe
*.class
*.jar

# Local/editor state
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.log
.env
.env.local
.env.*.local

# Documentation, reports, and media
docs/
reports/
snapshots/
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
favicon.ico
rh.ico
index.html
DLL_EXPORT_FILES_CREATED.txt
TODO.txt
TEMPLATE_polycall.c.example

# Windows helper scripts are host-side tooling, not image inputs.
build-windows.ps1

# Re-include the files and folders required by Dockerfile stages.
!CMakeLists.txt
!Makefile
!Dockerfile
!LICENSE
!README.md
!include/
!include/**
!src/
!src/**
!config/
!config/**
!bindings/
!bindings/**
!examples/
!examples/**

# Re-apply generated-output exclusions inside included source trees.
**/target/
**/target/**
**/dist/
**/dist/**
**/node_modules/
**/node_modules/**
**/__pycache__/
**/__pycache__/**
**/.pytest_cache/
**/.pytest_cache/**
*.o
*.a
*.so
*.dll
*.dylib
*.lib
*.exe
*.class
*.jar
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
